<p style="color: green"><%= notice %></p>
<% content_for :title, "Posts" %>

<!-- Create New Button Positioned at Top Right -->
<div class="container my-4">
  <div class="d-flex justify-content-end mb-3">
    <%= link_to "Create New", new_post_path, class: "btn btn-primary" %>
  </div>

  <h1 class="text-center">Blog Posts</h1>
  <div class="row">
    <% @posts.each do |post| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <img src="https://picsum.photos/300/200" class="card-img-top" alt="Post Image">
          <div class="card-body">
            <h5 class="card-title"><%= post.title %></h5>
            <p class="card-text"><%= truncate(post.body, length: 100) %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Posted on <%= post.created_at.strftime('%B %d, %Y') %></small>
            <%= link_to post, class: "text-primary" do %>
              <i class="bi bi-arrow-right-circle"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
