<div class="hero bg-dark text-white py-5">
    <div class="container text-center">
      <h1 class="display-4">Get in Touch</h1>
      <p class="lead">We'd love to hear from you! Fill out the form below and we'll get back to you as soon as possible.</p>
    </div>
  </div>
  <div class="container my-5">
    <div class="row">
      <div class="col-md-6">
        <img src="https://picsum.photos/600/400" alt="Contact Us Image" class="img-fluid rounded">
      </div>
      <div class="col-md-6">
        <h3>Contact Form</h3>
        <%= form_with url: contact_path, method: :post, local: true do |f| %>
          <div class="form-group">
            <%= f.label :name, "Your Name" %>
            <%= f.text_field :name, class: "form-control", placeholder: "Enter your name" %>
          </div>
          <div class="form-group">
            <%= f.label :email, "Your Email" %>
            <%= f.email_field :email, class: "form-control", placeholder: "Enter your email" %>
          </div>
          <div class="form-group">
            <%= f.label :message, "Your Message" %>
            <%= f.text_area :message, class: "form-control", rows: 5, placeholder: "Enter your message" %>
          </div>
          <%= f.submit "Send Message", class: "btn btn-primary mt-3" %>
        <% end %>
      </div>
    </div>
  </div>
  